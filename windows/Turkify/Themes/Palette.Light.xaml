<!--
  Açık tema renk paleti. Koyu tema (Palette.Dark.xaml) ile AYNI anahtar kümesini
  tanımlar; ThemeManager çalışma anında bu sözlüğü değiştirir. Kontrol stilleri
  (Controls.xaml) bu anahtarlara yalnızca DynamicResource ile erişir.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Yüzeyler -->
    <SolidColorBrush x:Key="App.Bg.Window"       Color="#F4F5F7" />
    <SolidColorBrush x:Key="App.Bg.Nav"          Color="#ECEEF1" />
    <SolidColorBrush x:Key="App.Bg.Surface"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="App.Bg.SurfaceAlt"   Color="#F6F7F9" />
    <SolidColorBrush x:Key="App.Bg.Control"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="App.Bg.ControlHover" Color="#EFF1F4" />

    <!-- Kenarlıklar -->
    <SolidColorBrush x:Key="App.Border"               Color="#E2E5EA" />
    <SolidColorBrush x:Key="App.Divider"              Color="#E8EBEF" />
    <SolidColorBrush x:Key="App.Control.Border"       Color="#CDD2DA" />
    <SolidColorBrush x:Key="App.Control.BorderHover"  Color="#A9B0BC" />

    <!-- Metin -->
    <SolidColorBrush x:Key="App.Text.Primary"    Color="#1B1E24" />
    <SolidColorBrush x:Key="App.Text.Secondary"  Color="#5C636E" />
    <SolidColorBrush x:Key="App.Text.Tertiary"   Color="#8A929E" />

    <!-- Vurgu (marka rengi: macOS varsayılanıyla uyumlu mavi) -->
    <SolidColorBrush x:Key="App.Accent"          Color="#2F6FE0" />
    <SolidColorBrush x:Key="App.Accent.Hover"    Color="#2A63C9" />
    <SolidColorBrush x:Key="App.Accent.Pressed"  Color="#244F9E" />
    <SolidColorBrush x:Key="App.Accent.Fg"       Color="#FFFFFF" />
    <SolidColorBrush x:Key="App.Accent.Subtle"   Color="#E6EEFB" />

    <!-- İkincil buton -->
    <SolidColorBrush x:Key="App.Button.Bg"       Color="#FFFFFF" />
    <SolidColorBrush x:Key="App.Button.Hover"    Color="#EFF1F4" />
    <SolidColorBrush x:Key="App.Button.Pressed"  Color="#E2E5EB" />
    <SolidColorBrush x:Key="App.Button.Border"   Color="#CDD2DA" />

    <!-- Durum -->
    <SolidColorBrush x:Key="App.Warning"         Color="#B45309" />

    <!-- Log kaynak etiketleri -->
    <SolidColorBrush x:Key="App.Log.System"      Color="#2F6FE0" />
    <SolidColorBrush x:Key="App.Log.Engine"      Color="#8048C8" />

    <!-- Kaydırma çubuğu -->
    <SolidColorBrush x:Key="App.Scroll.Thumb"      Color="#C4C9D1" />
    <SolidColorBrush x:Key="App.Scroll.ThumbHover" Color="#A9B0BC" />

</ResourceDictionary>
