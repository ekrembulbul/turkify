<Window x:Class="Turkify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Turkify"
        Title="Turkify"
        Icon="pack://application:,,,/Assets/Turkify.ico"
        Width="960" Height="680"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        Background="{DynamicResource App.Bg.Window}"
        Foreground="{DynamicResource App.Text.Primary}">

    <TabControl TabStripPlacement="Left">
        <!-- ============ Düzeltme ============ -->
        <TabItem Header="Düzeltme">
            <Grid Margin="22,18,22,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" Style="{StaticResource Text.Status}"
                               Text="{Binding CorrectionStatus}" />
                    <Button DockPanel.Dock="Right" x:Name="CorrectAndCopyButton"
                            Style="{StaticResource Button.Primary}" Margin="8,0,0,0" Click="OnCorrectAndCopy">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Düzelt ve Kopyala" VerticalAlignment="Center" />
                            <ContentControl Style="{StaticResource Keycap}" Content="Ctrl" />
                            <ContentControl Style="{StaticResource Keycap}" Content="↵" />
                        </StackPanel>
                    </Button>
                    <Button DockPanel.Dock="Right" x:Name="CorrectButton" Margin="8,0,0,0" Click="OnCorrect">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Düzelt" VerticalAlignment="Center" />
                            <ContentControl Style="{StaticResource Keycap}" Content="↵" />
                        </StackPanel>
                    </Button>
                    <Button DockPanel.Dock="Right" Content="Temizle"
                            Margin="8,0,0,0" Click="OnClearCorrection" />
                    <Button DockPanel.Dock="Right" x:Name="CancelTextButton" Margin="8,0,0,0" Click="OnCancelTextCorrection">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="İptal" VerticalAlignment="Center" />
                            <ContentControl Style="{StaticResource Keycap}" Content="Esc" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <DockPanel Grid.Row="1">
                    <TextBlock DockPanel.Dock="Top" Text="Metin" Style="{StaticResource Text.SectionHeader}"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding CorrectionInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="OnInputKeyDown" />
                </DockPanel>

                <DockPanel Grid.Row="2" Margin="0,12,0,0">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="Düzeltilmiş metin" Style="{StaticResource Text.SectionHeader}"
                                   Margin="0" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <Button x:Name="CopyOutputButton" Content="Kopyala" HorizontalAlignment="Right"
                                MinWidth="104" Padding="12,4" Click="OnCopyOutput" />
                    </Grid>
                    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource App.Bg.SurfaceAlt}"
                             Text="{Binding CorrectionOutput, Mode=OneWay}" />
                </DockPanel>
            </Grid>
        </TabItem>

        <!-- ============ Motor Ayarları ============ -->
        <TabItem Header="Motor Ayarları">
            <DockPanel Margin="22,18,22,20">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" Style="{StaticResource Text.Status}"
                               Text="{Binding LastStatus}" />
                    <Button DockPanel.Dock="Right" Content="Kaydet" Style="{StaticResource Button.Primary}"
                            MinWidth="150" Click="OnSaveSettings" />
                </DockPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Katmanlar" Style="{StaticResource Text.SectionHeader}" Margin="0,0,0,6" />
                        <CheckBox IsChecked="True" IsEnabled="False" Content="Tier 1 — Deterministik (her zaman açık)" />
                        <TextBlock Style="{StaticResource Text.Hint}" Text="Şapkaları kalıp tabanlı geri ekler. Hızlı, çevrimdışı temel düzeltme." />
                        <CheckBox x:Name="Tier2Check" Content="Tier 2 — Morfoloji + frekans"
                                  IsChecked="{Binding Settings.UseMorphology, Mode=TwoWay}" />
                        <TextBlock Style="{StaticResource Text.Hint}" Text="Geçersiz/belirsiz kelimeleri biçimbilim (zeyrek) ve sıklıkla çözer." />
                        <CheckBox x:Name="Tier3Check" Content="Tier 3 — LLM (bağlam)"
                                  IsChecked="{Binding Settings.UseLLM, Mode=TwoWay}" />
                        <TextBlock Style="{StaticResource Text.Hint}" Text="Birden çok geçerli aday bağlam gerektirdiğinde LLM seçer. OpenAI-uyumlu sunucu + model gerekir." />

                        <TextBlock Text="LLM bağlantısı (Tier 3)" Style="{StaticResource Text.SectionHeader}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="AutoRadio" Content="Otomatik" GroupName="ModelMode"
                                         Margin="0,5,18,5" Checked="OnModelModeChanged" />
                            <RadioButton x:Name="ManualRadio" Content="Manuel" GroupName="ModelMode"
                                         Checked="OnModelModeChanged" />
                        </StackPanel>
                        <StackPanel x:Name="AutoPanel" Orientation="Horizontal" Margin="0,0,0,6">
                            <ComboBox x:Name="ModelCombo" Width="340"
                                      SelectionChanged="OnModelSelected" />
                            <Button Content="↻" Width="34" Padding="0" Margin="8,0,0,0" Click="OnRefreshModels"
                                    ToolTip="Yerel modelleri yeniden tara" />
                        </StackPanel>

                        <TextBlock Text="Model" Style="{StaticResource Text.FieldLabel}" />
                        <TextBox x:Name="ModelBox" Text="{Binding Settings.Model, Mode=TwoWay}" />
                        <TextBlock Text="Sunucu (base_url)" Style="{StaticResource Text.FieldLabel}" />
                        <TextBox x:Name="BaseUrlBox" Text="{Binding Settings.BaseURL, Mode=TwoWay}" />
                        <TextBlock Text="API anahtarı" Style="{StaticResource Text.FieldLabel}" />
                        <TextBox Text="{Binding Settings.ApiKey, Mode=TwoWay}" />
                        <TextBlock Text="Zaman aşımı (sn)" Style="{StaticResource Text.FieldLabel}" />
                        <TextBox Width="90" HorizontalAlignment="Left"
                                 Text="{Binding Settings.Timeout, Mode=TwoWay}" />

                        <TextBlock Text="assistant_prefill" Style="{StaticResource Text.SectionHeader}" />
                        <TextBlock Style="{StaticResource Text.Hint}" Text="İsteğe eklenecek asistan metni. Düşünmeyi kapatmak için: &lt;think&gt;\n\n&lt;/think&gt;\n\n" />
                        <TextBox Height="54" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Settings.AssistantPrefill, Mode=TwoWay}" />

                        <TextBlock Text="llm_options (JSON)" Style="{StaticResource Text.SectionHeader}" />
                        <TextBlock Style="{StaticResource Text.Hint}" Text="İsteğin gövdesine eklenecek JSON. Ör: {&quot;chat_template_kwargs&quot;:{&quot;enable_thinking&quot;:false}}" />
                        <TextBox x:Name="LlmOptionsBox" Height="74" AcceptsReturn="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" VerticalScrollBarVisibility="Auto"
                                 TextChanged="OnLlmOptionsChanged"
                                 Text="{Binding Settings.LlmOptions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock x:Name="JsonWarning" Foreground="{DynamicResource App.Warning}" FontSize="11"
                                   Margin="0,4,0,0" Visibility="Collapsed"
                                   Text="Geçersiz JSON — kaydedilse de motora gönderilmez." />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <!-- ============ Diğer Ayarlar ============ -->
        <TabItem Header="Diğer Ayarlar">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                <StackPanel Margin="22,4,22,20">
                    <TextBlock Text="Görünüm" Style="{StaticResource Text.SectionHeader}" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ThemeAutoRadio" Content="Otomatik" GroupName="ThemeMode"
                                     Margin="0,5,18,5" Checked="OnThemeChanged" />
                        <RadioButton x:Name="ThemeLightRadio" Content="Açık" GroupName="ThemeMode"
                                     Margin="0,5,18,5" Checked="OnThemeChanged" />
                        <RadioButton x:Name="ThemeDarkRadio" Content="Koyu" GroupName="ThemeMode"
                                     Margin="0,5" Checked="OnThemeChanged" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource Text.Hint}"
                               Text="“Otomatik” seçiliyse Windows’ta hangi mod aktifse (açık/koyu) o uygulanır ve sistem teması değişince anında güncellenir." />

                    <TextBlock Text="Kısayollar" Style="{StaticResource Text.SectionHeader}" />
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Düzeltme" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="CorrectionHotkeyText" VerticalAlignment="Center"
                                   FontFamily="Consolas" />
                        <Button Grid.Column="2" x:Name="RecordCorrectionButton" Content="Değiştir"
                                Padding="12,4" Click="OnRecordCorrectionHotkey" />
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="İşlemi iptal" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="CancelHotkeyText" VerticalAlignment="Center"
                                   FontFamily="Consolas" />
                        <Button Grid.Column="2" x:Name="RecordCancelButton" Content="Değiştir"
                                Padding="12,4" Click="OnRecordCancelHotkey" />
                    </Grid>
                    <TextBlock x:Name="HotkeyHint" Style="{StaticResource Text.Hint}"
                               Text="“Değiştir”e basıp istediğiniz kombinasyona basın. En az bir Ctrl/Alt/Win ve bir harf/rakam. (Esc: iptal)" />

                    <TextBlock Text="Başlangıç" Style="{StaticResource Text.SectionHeader}" />
                    <CheckBox x:Name="StartupCheck" Content="Windows ile başlat"
                              Click="OnToggleStartup" />
                    <TextBlock Style="{StaticResource Text.Hint}"
                               Text="Oturum açılışında Turkify tray’de otomatik başlar." />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ============ Korumalı Kelimeler ============ -->
        <TabItem Header="Korumalı Kelimeler">
            <DockPanel Margin="22,18,22,20">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="520"
                               Style="{StaticResource Text.Hint}" Margin="0"
                               Text="Bu kelimeler düzeltilmez (her satıra bir kelime). Yalnızca buradaki kelimeler korunur." />
                    <Button DockPanel.Dock="Right" Content="Kaydet" Style="{StaticResource Button.Primary}"
                            MinWidth="150" Click="OnSaveProtectedWords" />
                </DockPanel>
                <TextBox x:Name="ProtectedWordsBox" AcceptsReturn="True" TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
            </DockPanel>
        </TabItem>

        <!-- ============ Log ============ -->
        <TabItem Header="Log">
            <DockPanel Margin="22,18,22,20">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,10">
                    <ComboBox DockPanel.Dock="Left" x:Name="LogFilterCombo" Width="170"
                              SelectionChanged="OnLogFilterChanged">
                        <ComboBoxItem Content="Tümü" />
                        <ComboBoxItem Content="Sistem" />
                        <ComboBoxItem Content="Motor" />
                    </ComboBox>
                    <Button DockPanel.Dock="Right" Content="Temizle" Padding="12,4" Click="OnClearLog" />
                    <TextBlock DockPanel.Dock="Right" x:Name="LogCountText" VerticalAlignment="Center"
                               Margin="0,0,12,0" Foreground="{DynamicResource App.Text.Tertiary}" />
                </DockPanel>
                <ListBox x:Name="LogList" FontFamily="Consolas" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Time}" Foreground="{DynamicResource App.Text.Tertiary}" Margin="0,0,8,0" />
                                <TextBlock x:Name="SourceText" Text="{Binding SourceLabel}" Margin="0,0,8,0"
                                           Foreground="{DynamicResource App.Log.Engine}" />
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource App.Text.Primary}" />
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Source}" Value="{x:Static local:LogSource.System}">
                                    <Setter TargetName="SourceText" Property="Foreground" Value="{DynamicResource App.Log.System}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
